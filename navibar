// Improved version of src/components/Navbar.tsx
import { Link } from "@tanstack/react-router";
import { useState } from "react";
import { Menu } from "lucide-react";
import { Sheet, SheetContent, SheetTrigger, SheetTitle } from "./ui/sheet";
import { CartDrawer } from "./CartDrawer";
import { useScroll } from "@/hooks/use-scroll";
import { MAIN_NAVIGATION, CTA_BUTTONS } from "@/config/navigation";
import logo from "../assets/logo.jpg";

/**
 * Main navigation header component
 * Features:
 * - Sticky header with scroll-aware styling
 * - Responsive mobile/desktop layouts
 * - Keyboard-accessible navigation
 */
export function Navbar() {
  // Use custom scroll hook for cleaner code
  const scrolled = useScroll(12);
  const [mobileMenuOpen, setMobileMenuOpen] = useState(false);

  return (
    <header
      className={`sticky top-0 z-50 w-full transition-all duration-300 ${
        scrolled
          ? "border-b border-border/60 bg-background/85 backdrop-blur-xl shadow-sm"
          : "bg-background/40 backdrop-blur-sm"
      }`}
      role="banner"
    >
      <nav
        className="mx-auto flex h-16 max-w-7xl items-center justify-between gap-4 px-4 sm:px-6 lg:px-8"
        aria-label="Main navigation"
      >
        <NavLogo />

        {/* Desktop Navigation */}
        <DesktopNav />

        {/* Right section with buttons and cart */}
        <NavActions mobileMenuOpen={mobileMenuOpen} setMobileMenuOpen={setMobileMenuOpen} />
      </nav>
    </header>
  );
}

/**
 * Logo and branding section
 */
function NavLogo() {
  return (
    <Link
      to="/"
      className="flex items-center gap-2 group"
      aria-label="De Kaaskantine home"
    >
      <img
        src={logo}
        alt="De Kaaskantine logo"
        className="h-10 w-10 shrink-0 rounded-full object-cover shadow-sm ring-1 ring-border transition-transform group-hover:scale-105"
      />
      <span className="font-display text-lg font-semibold tracking-tight text-primary sm:text-xl">
        De Kaaskantine
      </span>
    </Link>
  );
}

/**
 * Desktop navigation menu (hidden on mobile)
 */
function DesktopNav() {
  return (
    <ul
      className="hidden items-center gap-1 lg:flex"
      role="menubar"
    >
      {MAIN_NAVIGATION.map((item) => (
        <li key={item.to} role="none">
          <Link
            to={item.to}
            className="rounded-full px-3 py-2 text-sm font-medium text-foreground/80 transition-colors hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
            activeProps={{
              className: "text-primary",
            }}
            activeOptions={{
              exact: item.to === "/",
            }}
            title={item.description}
            role="menuitem"
          >
            {item.label}
          </Link>
        </li>
      ))}
    </ul>
  );
}

/**
 * Right side actions: CTA button, cart, and mobile menu
 */
function NavActions({
  mobileMenuOpen,
  setMobileMenuOpen,
}: {
  mobileMenuOpen: boolean;
  setMobileMenuOpen: (open: boolean) => void;
}) {
  return (
    <div className="flex items-center gap-2">
      {/* Desktop CTA Button */}
      <Link
        to={CTA_BUTTONS.primary.to}
        className="hidden rounded-full bg-[var(--brand-gold)] px-5 py-2.5 text-sm font-semibold text-primary shadow-sm transition-all hover:shadow-md hover:-translate-y-0.5 hover:bg-[var(--brand-gold-soft)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring sm:inline-flex"
      >
        {CTA_BUTTONS.primary.label}
      </Link>

      {/* Cart Drawer */}
      <CartDrawer />

      {/* Mobile Menu Trigger */}
      <MobileMenuTrigger
        isOpen={mobileMenuOpen}
        onOpenChange={setMobileMenuOpen}
      />
    </div>
  );
}

/**
 * Mobile menu sheet trigger and content
 */
function MobileMenuTrigger({
  isOpen,
  onOpenChange,
}: {
  isOpen: boolean;
  onOpenChange: (open: boolean) => void;
}) {
  return (
    <Sheet open={isOpen} onOpenChange={onOpenChange}>
      <SheetTrigger
        className="grid h-11 w-11 place-items-center rounded-full border border-border bg-background text-primary lg:hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
        aria-label="Open navigation menu"
        title="Menu"
      >
        <Menu className="h-5 w-5" />
      </SheetTrigger>

      <SheetContent
        side="right"
        className="w-full max-w-sm bg-background p-6"
        role="dialog"
        aria-label="Navigation menu"
      >
        <SheetTitle className="font-display text-2xl text-primary">
          Menu
        </SheetTitle>

        {/* Mobile Navigation Links */}
        <nav className="mt-8">
          <ul className="flex flex-col gap-1" role="menubar">
            {MAIN_NAVIGATION.map((item) => (
              <li key={item.to} role="none">
                <Link
                  to={item.to}
                  onClick={() => onOpenChange(false)}
                  className="block rounded-xl px-4 py-3 text-lg font-medium text-foreground/90 transition-colors hover:bg-secondary hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
                  activeProps={{
                    className: "bg-secondary text-primary",
                  }}
                  activeOptions={{
                    exact: item.to === "/",
                  }}
                  role="menuitem"
                >
                  {item.label}
                </Link>
              </li>
            ))}
          </ul>
        </nav>

        {/* Mobile CTA Button */}
        <Link
          to={CTA_BUTTONS.primary.to}
          onClick={() => onOpenChange(false)}
          className="mt-6 inline-flex w-full items-center justify-center rounded-full bg-[var(--brand-gold)] px-5 py-3 text-base font-semibold text-primary shadow-sm hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
        >
          {CTA_BUTTONS.primary.label}
        </Link>
      </SheetContent>
    </Sheet>
  );
}
