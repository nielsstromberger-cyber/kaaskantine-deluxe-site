### 2.1 Enhance Cart Store Types
**Issue:** Missing strict typing for some operations.

**Improvements:**
```typescript
// src/lib/cart-store.ts - Enhanced types
import { create } from "zustand";
import { persist } from "zustand/middleware";

export type CartItem = {
  productId: string;
  name: string;
  priceCents: number;
  quantity: number;
  notes?: string;
};

export type AddItemPayload = Omit<CartItem, "quantity">;

type CartState = {
  items: CartItem[];
  add: (item: AddItemPayload, qty?: number) => void;
  remove: (productId: string) => void;
  setQuantity: (productId: string, qty: number) => void;
  clear: () => void;
  subtotalCents: () => number;
  count: () => number;
  // Add computed properties
  readonly isEmpty: boolean;
  readonly itemCount: number;
  getItem: (productId: string) => CartItem | undefined;
};

export const useCart = create<CartState>()(
  persist(
    (set, get) => ({
      items: [],
      add: (item: AddItemPayload, qty = 1) => {
        // validation
        if (qty < 1) throw new Error("Quantity must be at least 1");
        if (!item.productId) throw new Error("Product ID is required");
        
        set((s) => {
          const existing = s.items.find((i) => i.productId === item.productId);
          if (existing) {
            return {
              items: s.items.map((i) =>
                i.productId === item.productId 
                  ? { ...i, quantity: i.quantity + qty } 
                  : i,
              ),
            };
          }
          return { items: [...s.items, { ...item, quantity: qty }] };
        });
      },
      remove: (productId: string) =>
        set((s) => ({ items: s.items.filter((i) => i.productId !== productId) })),
      setQuantity: (productId: string, qty: number) => {
        if (qty < 0) throw new Error("Quantity cannot be negative");
        set((s) => ({
          items:
            qty === 0
              ? s.items.filter((i) => i.productId !== productId)
              : s.items.map((i) => 
                  i.productId === productId ? { ...i, quantity: qty } : i
                ),
        }));
      },
      clear: () => set({ items: [] }),
      subtotalCents: () => get().items.reduce((sum, i) => sum + i.priceCents * i.quantity, 0),
      count: () => get().items.reduce((sum, i) => sum + i.quantity, 0),
      get isEmpty() {
        return get().items.length === 0;
      },
      get itemCount() {
        return get().count();
      },
      getItem: (productId: string) => get().items.find(i => i.productId === productId),
    }),
    { name: "kaaskantine-cart-v1" },
  ),
);

export const formatEUR = (cents: number): string =>
  new Intl.NumberFormat("nl-NL", { 
    style: "currency", 
    currency: "EUR",
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  }).format(cents / 100);
```

**Impact:** Better IDE support, earlier error detection, cleaner code

