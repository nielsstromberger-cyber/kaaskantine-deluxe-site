  trackEvent: (event: AnalyticsEvent) => {
    if (typeof window !== 'undefined') {
      // Send to your analytics service (GA, Posthog, etc.)
      console.debug('Analytics event:', event);
    }
  },
  trackCartAdd: (productId: string, quantity: number, priceCents: number) => {
    analytics.trackEvent({
      name: 'add_to_cart',
      properties: { productId, quantity, priceCents },
    });
  },
  trackCheckout: (subtotalCents: number, itemCount: number) => {
    analytics.trackEvent({
      name: 'begin_checkout',
      properties: { subtotalCents, itemCount },
    });
  },
};
